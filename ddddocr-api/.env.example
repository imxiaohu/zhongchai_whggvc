# ============================================================
# ddddocr-api 环境变量配置
# 复制此文件为 .env 后根据实际情况修改
# ============================================================

# 服务端口（ddddocr API 服务监听端口）
# 建议与 go_backend/.env 中 OCR_SERVICE_URL 保持一致
OCR_PORT=8899

# Worker 数量（每个 worker 约占用 300MB 内存）
# 1: 低配服务器 / 开发环境
# 2: 中等配置（推荐）
# 4: 高并发场景，需要更多内存
OCR_WORKERS=2

# 是否使用 Beta 模型（更准确但首次下载更慢）
# true:  使用更新更大的模型，识别率更高
# false: 使用稳定版模型（默认）
OCR_BETA=false

# 是否使用 GPU 加速
# true:  需要 NVIDIA GPU + nvidia-docker 支持，识别速度提升 5-10x
# false: 使用 CPU（默认）
# 注意：启用 GPU 需要在 docker-compose.yml 中添加 deploy.resources.reservations.reservableDevices
OCR_USE_GPU=false

# ============================================================
# 资源限制（生产环境建议配置，开发环境可忽略）
# ============================================================

# CPU 限制（核心数）
OCR_CPU_LIMIT=2

# 内存限制
# 1G: 仅 1 worker，低配服务器
# 2G: 2 workers（推荐）
# 4G: 4 workers，高并发
OCR_MEM_LIMIT=2G

# CPU 预留（Guaranteed QoS）
OCR_CPU_RESERVE=0.5

# 内存预留
OCR_MEM_RESERVE=512M
