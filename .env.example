# 前端环境变量配置
# 复制此文件为 .env.local 并修改相应配置

# 后端 API 地址（生产环境）
VITE_API_BASE_URL=https://api.your-domain.com

# Go 服务器地址
VITE_GO_SERVER_URL=https://go.your-domain.com

# 学校文件服务器地址（用于附件下载等）
VITE_SCHOOL_FILE_SERVER_URL=https://scs.your-school-domain.com

# 学校服务器地址（用于代理请求等）
VITE_SCHOOL_SERVER_URL=https://xs.your-school-domain.com
