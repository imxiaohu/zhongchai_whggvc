{
  "压测配置": {
    "服务器地址": "https://go.your-domain.com",
    "备用地址": [
      "http://localhost:2333",
      "https://test.your-domain.com",
      "https://staging.your-domain.com"
    ],
    "默认模式": "快速",
    "输出目录": "./压测结果",
    "日志级别": "info"
  },
  "测试模式": {
    "快速": {
      "描述": "快速测试，适用于开发和初始验证",
      "最大并发数": 100,
      "预热时长_秒": 30,
      "测试时长_秒": 120,
      "请求间隔_毫秒": 0,
      "超时时间_秒": 30,
      "启用认证": false,
      "推荐使用场景": "开发环境、初始测试、CI/CD流水线"
    },
    "中等": {
      "描述": "中等规模测试，适用于预生产验证",
      "最大并发数": 1000,
      "预热时长_秒": 60,
      "测试时长_秒": 180,
      "请求间隔_毫秒": 0,
      "超时时间_秒": 30,
      "启用认证": false,
      "推荐使用场景": "预生产测试、性能验证"
    },
    "完整": {
      "描述": "完整规模测试，用于生产容量测试",
      "最大并发数": 10000,
      "预热时长_秒": 120,
      "测试时长_秒": 300,
      "请求间隔_毫秒": 0,
      "超时时间_秒": 30,
      "启用认证": false,
      "推荐使用场景": "生产容量测试、压力测试"
    },
    "认证": {
      "描述": "认证流程测试",
      "最大并发数": 500,
      "预热时长_秒": 60,
      "测试时长_秒": 180,
      "请求间隔_毫秒": 0,
      "超时时间_秒": 30,
      "启用认证": true,
      "测试用户名": "test_user",
      "测试密码": "test_password",
      "推荐使用场景": "认证系统测试、登录流程验证"
    }
  },
  "测试接口": [
    {
      "接口名称": "健康检查",
      "请求方法": "GET",
      "接口路径": "/api/health/school-server",
      "需要认证": false,
      "权重": 30,
      "期望状态码": [200],
      "描述": "服务器健康监控接口"
    },
    {
      "接口名称": "系统初始化",
      "请求方法": "GET",
      "接口路径": "/scloud/init",
      "需要认证": false,
      "权重": 20,
      "期望状态码": [200],
      "描述": "系统初始化接口"
    },
    {
      "接口名称": "用户信息",
      "请求方法": "GET",
      "接口路径": "/api/user/info",
      "需要认证": true,
      "权重": 25,
      "期望状态码": [200, 401],
      "描述": "用户信息获取"
    },
    {
      "接口名称": "社团列表",
      "请求方法": "GET",
      "接口路径": "/api/clubs",
      "需要认证": true,
      "权重": 25,
      "期望状态码": [200, 401],
      "描述": "社团列表接口"
    }
  ],
  "性能阈值": {
    "最低成功率": 95.0,
    "平均响应时间_毫秒": 500,
    "95百分位响应时间_毫秒": 2000,
    "99百分位响应时间_毫秒": 5000,
    "最低每秒请求数": 100,
    "最高错误率": 5.0
  },
  "监控设置": {
    "实时统计间隔_秒": 10,
    "启用详细日志": true,
    "保存原始结果": false,
    "生成图表": false
  },
  "安全设置": {
    "高并发警告阈值": 5000,
    "高负载需要确认": true,
    "高错误率自动停止": true,
    "错误率停止阈值": 50.0,
    "测试前连接检查": true
  },
  "输出设置": {
    "默认输出目录": "./压测结果",
    "文件名包含时间戳": true,
    "生成JSON报告": true,
    "生成CSV报告": false,
    "压缩大型报告": false
  },
  "认证配置": {
    "测试用户名": "test_user",
    "测试密码": "test_password",
    "登录接口": "/scloud/login",
    "令牌头名称": "X-Access-Token",
    "令牌过期缓冲_秒": 300
  },
  "高级设置": {
    "HTTP客户端": {
      "最大空闲连接": 1000,
      "每主机最大空闲连接": 500,
      "空闲连接超时_秒": 30,
      "禁用保持连接": false,
      "禁用压缩": false
    },
    "请求分发": {
      "使用权重选择": true,
      "随机化接口选择": false,
      "遵循接口权重": true
    },
    "错误处理": {
      "重试失败请求": false,
      "最大重试次数": 3,
      "重试延迟_毫秒": 1000,
      "忽略证书错误": true
    }
  },
  "报告配置": {
    "包含百分位数": [50, 75, 90, 95, 99],
    "包含响应时间直方图": true,
    "包含错误详情": true,
    "包含接口分解": true,
    "包含性能建议": true,
    "建议规则": {
      "高错误率": "建议减少负载或检查服务器容量",
      "慢响应时间": "建议优化服务器性能或数据库查询",
      "高95百分位延迟": "部分请求存在明显延迟",
      "低吞吐量": "服务器可能能够处理更高的负载"
    }
  },
  "元数据": {
    "版本": "1.0.0",
    "创建日期": "2024-12-19",
    "描述": "Go后端服务器压力测试配置",
    "作者": "压测工具",
    "最后更新": "2024-12-19"
  }
}
