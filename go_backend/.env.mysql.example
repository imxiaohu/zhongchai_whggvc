# MySQL数据库配置示例
# 复制此文件为 .env 并修改相应配置

# 数据库类型（sqlite 或 mysql）
DB_TYPE=mysql

# MySQL数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=pingjiao
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=pingjiao
MYSQL_CHARSET=utf8mb4

# 服务器配置
PORT=8081
GIN_MODE=release

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=2592000

# 学校服务器配置
SCHOOL_SERVER_URL=https://xs.whggvc.net

# 学校密码可解密加密密钥（32字节；可直接填32字符，或填 base64(32字节)）
SCHOOL_PASSWORD_ENC_KEY=0123456789abcdef0123456789abcdef

# 离线缓存定时任务
OFFLINE_CACHE_SCHEDULER_ENABLED=true
OFFLINE_CACHE_SCHEDULER_TZ=Local
OFFLINE_CACHE_CLASS_SCHEDULE_MAX_WEEK=20

# CORS配置
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-domain.com

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
