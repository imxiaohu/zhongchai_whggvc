# MySQL数据库配置示例
# 复制此文件为 .env 并修改相应配置

# 数据库类型（sqlite 或 mysql）
DB_TYPE=mysql

# MySQL数据库配置
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
MYSQL_CHARSET=utf8mb4

# 服务器配置
PORT=2333
GIN_MODE=release

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=2592000

# 学校服务器配置
SCHOOL_SERVER_URL=https://xs.whggvc.net

# 学校密码加密密钥（32字节，用于 AES-GCM 加密存储学校账号密码）
SCHOOL_PASSWORD_ENC_KEY=your_32_byte_base64_encoded_key

# CORS配置
CORS_ALLOW_ORIGINS=https://your-domain.com,http://localhost:5173,https://localhost:5173

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Redis缓存配置
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_ENABLED=true

# 缓存配置
CACHE_ENABLED=true
CACHE_TYPE=redis
CACHE_TTL=300

# 七牛云存储配置
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=your_domain
QINIU_ZONE=huanan
QINIU_USE_HTTPS=false
QINIU_USE_CDN=true

# RabbitMQ配置
RABBITMQ_ENABLED=true
RABBITMQ_HOST=your_rabbitmq_host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_username
RABBITMQ_PASSWORD=your_password
RABBITMQ_VHOST=/your_vhost

# 邮件服务配置
EMAIL_ENABLED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_email_password

# 阿里云短信配置
SMS_ENABLED=true
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_REGION=cn-hangzhou
SMS_TEMPLATE_SCORE_UPDATE=your_template_code
SMS_TEMPLATE_SCORE_TEST=your_template_code
SMS_TEMPLATE_SYSTEM=your_template_code
SMS_SIGN_NAME=your_sign_name

# 微信支付配置
WECHAT_PAY_ENABLED=true
WECHAT_PAY_APP_ID=your_app_id
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_V2_KEY=your_api_v2_key
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial_no
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/callback
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_CERT_PATH=./certs/apiclient_cert.pem

# 微信小程序配置（更新为新的）
WECHAT_MINI_APP_ID=your_mini_app_id
WECHAT_MINI_APP_SECRET=your_mini_app_secret

# OCR验证码识别服务（ddddocr微服务）
# 本地开发：确保 ddddocr-api 服务已启动
# 远程部署：填写内网可访问的 OCR 服务地址
OCR_SERVICE_URL=http://127.0.0.1:8899
# OCR 识别超时时间（毫秒），ddddocr 模型加载较慢，建议 15-30 秒
OCR_TIMEOUT_MS=15000
